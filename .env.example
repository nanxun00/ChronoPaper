# ChronoPaper 环境配置模板
# 复制为 .env 并填入真实值：cp .env.example .env

# ========== LLM API Keys ==========
OPENAI_API_KEY=
OPENAI_API_BASE=
DEEPSEEK_API_KEY=
ZHIPUAI_API_KEY=
DASHSCOPE_API_KEY=

# ========== 科大讯飞语音听写 ==========
XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=

SILICONFLOW_API_KEY=
MIMO_API_KEY=
# 按量计费默认 https://api.xiaomimimo.com/v1 ；Token Plan 请改为订阅页提供的 Base URL
MIMO_API_BASE=https://api.xiaomimimo.com/v1
QIANFAN_ACCESS_KEY=
QIANFAN_SECRET_KEY=

# 本地 Ollama / OpenAI 兼容接口
OLLAMA_API_BASE=
OLLAMA_API_KEY=
MODEL_LOCAL_DIR=local

# ========== 图像生成（聊天「图像生成」工具）==========
IMAGE_GEN_API_BASE=https://api.openai-proxy.org/v1
IMAGE_GEN_API_KEY=
IMAGE_GEN_MODEL=gpt-image-2-2026-04-21

# ========== MySQL（MYSQL_PROFILE=local|remote 切换）==========
# local：本地开发；remote：远程库（需在下方填写 MYSQL_REMOTE_*）
MYSQL_PROFILE=local

# --- local ---
MYSQL_LOCAL_USER=
MYSQL_LOCAL_PASSWORD=
MYSQL_LOCAL_HOST=
MYSQL_LOCAL_PORT=3306
MYSQL_LOCAL_DB=chronopaper

# --- remote ---
MYSQL_REMOTE_USER=
MYSQL_REMOTE_PASSWORD=
MYSQL_REMOTE_HOST=
MYSQL_REMOTE_PORT=3306
MYSQL_REMOTE_DB=chronopaper

# 兼容旧写法（映射到 local）
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_DB=chronopaper

# ========== Neo4j ==========
# Bolt 示例：bolt://127.0.0.1:7687（Docker 常见映射如 host:8043→7687）
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Neo4j Legacy（留空则复用主库）
NEO4J_LEGACY_URI=
NEO4J_LEGACY_USERNAME=
NEO4J_LEGACY_PASSWORD=

# ========== Milvus / 知识库 ==========
MILVUS_URI=
MILVUS_TOKEN=
MILVUS_DB_NAME=chronopaper

# Celery / Redis（向量入库异步任务）
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
# uvicorn 启动时自动拉起 celery worker（Docker 多容器部署可设为 false）
AUTO_START_CELERY_WORKER=true

# 数据与知识库登记（未设置时回退到 config.yaml）
SAVE_DIR=
KB_DATABASE_JSON=
ENABLE_KNOWLEDGE_BASE=
ENABLE_KNOWLEDGE_GRAPH=
ENABLE_SEMANTIC_SCHOLAR_CITE=true
ENABLE_RERANKER=
ENABLE_SEARCH_ENGINE=
EMBED_MODEL=
RERANKER=

# ========== MinIO ==========
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=false
MINIO_BUCKET=image

# ========== JWT / AES ==========
JWT_SECRET_KEY=
AES_KEY=
AES_IV=
TOKEN_EXPIRES_TIME=43200
TOKEN_DEFAULT_EXPIRES_TIME=15

# ========== MemOS 长期记忆（ModelScope Hosted MCP）==========
# 在 ModelScope MCP 广场创建 MemOS 服务后填写 URL；无 Token 时留空
MEMOS_ENABLED=false
MEMOS_URL=
MEMOS_AUTH_TOKEN=

# ========== 运行环境（Windows 建议设置，避免 Roaming 用户包污染 conda）==========
# PowerShell 启动后端前执行：$env:PYTHONNOUSERSITE="1"
# 若曾 pip install --user tensorflow，建议在 Roaming site-packages 中卸载 tensorflow/keras
GATEWAY_TIME_OUT=90
