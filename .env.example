# ChronoPaper 环境配置模板
# 复制为 .env 并填入真实值：cp .env.example .env

# ========== LLM API Keys ==========
OPENAI_API_KEY=
OPENAI_API_BASE=
DEEPSEEK_API_KEY=
ZHIPUAI_API_KEY=
DASHSCOPE_API_KEY=
SILICONFLOW_API_KEY=
QIANFAN_ACCESS_KEY=
QIANFAN_SECRET_KEY=

# 本地 Ollama / OpenAI 兼容接口
OLLAMA_API_BASE=
OLLAMA_API_KEY=
MODEL_LOCAL_DIR=local

# ========== MySQL（MYSQL_PROFILE=local|remote 切换）==========
# local：本地开发；remote：远程库（需在下方填写 MYSQL_REMOTE_*）
MYSQL_PROFILE=local

# --- local ---
MYSQL_LOCAL_USER=
MYSQL_LOCAL_PASSWORD=
MYSQL_LOCAL_HOST=
MYSQL_LOCAL_PORT=3306
MYSQL_LOCAL_DB=chronopaper

# --- remote ---
MYSQL_REMOTE_USER=
MYSQL_REMOTE_PASSWORD=
MYSQL_REMOTE_HOST=
MYSQL_REMOTE_PORT=3306
MYSQL_REMOTE_DB=chronopaper

# 兼容旧写法（映射到 local）
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_DB=chronopaper

# ========== Neo4j ==========
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# Neo4j Legacy（留空则复用主库）
NEO4J_LEGACY_URI=
NEO4J_LEGACY_USERNAME=
NEO4J_LEGACY_PASSWORD=

# ========== Milvus / 知识库 ==========
MILVUS_URI=
MILVUS_TOKEN=
MILVUS_DB_NAME=default

# 数据与知识库登记（未设置时回退到 config.yaml）
SAVE_DIR=
KB_DATABASE_JSON=
ENABLE_KNOWLEDGE_BASE=
ENABLE_KNOWLEDGE_GRAPH=
ENABLE_RERANKER=
ENABLE_SEARCH_ENGINE=
EMBED_MODEL=
RERANKER=

# ========== MinIO ==========
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=false
MINIO_BUCKET=image

# ========== JWT / AES ==========
JWT_SECRET_KEY=
AES_KEY=
AES_IV=
TOKEN_EXPIRES_TIME=43200
TOKEN_DEFAULT_EXPIRES_TIME=15

# ========== 网关 ==========
GATEWAY_TIME_OUT=90
