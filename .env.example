# ChronoPaper 环境配置模板
# 复制为 .env 并填入真实值：cp .env.example .env

# ========== LLM API Keys ==========
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
DEEPSEEK_API_KEY=
ZHIPUAI_API_KEY=
DASHSCOPE_API_KEY=
SILICONFLOW_API_KEY=
QIANFAN_ACCESS_KEY=
QIANFAN_SECRET_KEY=

# 本地 Ollama / OpenAI 兼容接口
OLLAMA_API_BASE=http://localhost:11434/v1/
OLLAMA_API_KEY=ollama
MODEL_LOCAL_DIR=local

# ========== MySQL ==========
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_DB=chronopaper

# ========== Neo4j（主库）==========
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Neo4j Legacy（图谱上传模块，留空则复用主库）
NEO4J_LEGACY_URI=
NEO4J_LEGACY_USERNAME=neo4j
NEO4J_LEGACY_PASSWORD=

# ========== Milvus ==========
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default

# ========== MinIO（可选）==========
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_SECURE=false
MINIO_BUCKET=image

# ========== JWT / AES ==========
JWT_SECRET_KEY=
AES_KEY=
AES_IV=
TOKEN_EXPIRES_TIME=43200
TOKEN_DEFAULT_EXPIRES_TIME=15

# ========== 网关 ==========
GATEWAY_TIME_OUT=90
