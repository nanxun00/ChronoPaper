# ChronoPaper 环境配置模板
# 复制为 .env 并填入真实值：cp .env.example .env

# ========== LLM API Keys ==========
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
DEEPSEEK_API_KEY=
ZHIPUAI_API_KEY=
DASHSCOPE_API_KEY=
SILICONFLOW_API_KEY=
QIANFAN_ACCESS_KEY=
QIANFAN_SECRET_KEY=

# 本地 Ollama / OpenAI 兼容接口
OLLAMA_API_BASE=http://localhost:11434/v1/
OLLAMA_API_KEY=ollama
MODEL_LOCAL_DIR=local

# ========== MySQL ==========
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=chronopaper

# ========== Neo4j（HTTP 7074→7474，Bolt 7075→7687）==========
NEO4J_URI=neo4j://localhost:7075
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=0123456789

# Neo4j Legacy（图谱上传模块，留空则复用主库）
NEO4J_LEGACY_URI=
NEO4J_LEGACY_USERNAME=neo4j
NEO4J_LEGACY_PASSWORD=

# ========== Milvus（核心 7072→19530，健康检查 7073→9091）==========
MILVUS_URI=http://localhost:7072
MILVUS_TOKEN=
MILVUS_DB_NAME=default

# ========== MinIO（API 7070→9000，Web 7071→9001）==========
MINIO_ENDPOINT=localhost:7070
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=image

# ========== JWT / AES ==========
JWT_SECRET_KEY=
AES_KEY=
AES_IV=
TOKEN_EXPIRES_TIME=43200
TOKEN_DEFAULT_EXPIRES_TIME=15

# ========== 网关 ==========
GATEWAY_TIME_OUT=90
